  author = {Avery, Anthony J and Rodgers, Sarah and Cantrill, Judith A and Armstrong, Sarah and Cresswell, Kathrin and Eden, Martin and Elliott, Rachel A and Howard, Rachel and Kendrick, Denise and Morris, Caroline J and Prescott, Robin J and Swanwick, Glen and Franklin, Matthew and Putman, Koen and Boyd, Matthew and Sheikh, Aziz},
  journal = {The Lancet},
  volume = {379},
  number = {9823},
